<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MEMOMed.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MEMOMed.Views.TableView"
             x:DataType="vm:TableViewModel">

    <Design.DataContext>
        <vm:TableViewModel />
    </Design.DataContext>

    <DockPanel Margin="10">
        <!-- Navigation Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <Button Command="{Binding GoBackCommand}" Content="Go Back" MinWidth="60" />
            <Button Command="{Binding HeartPChangeCommand}" Content="Heart Measurements" MinWidth="100" />
            <Button Command="{Binding BodyPChangeCommand}" Content="Body Measurements" MinWidth="100" />
            <Button Command="{Binding MedicinePChangeCommand}" Content="Medicine List" MinWidth="100" />
        </StackPanel>

        <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="15">
                <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding Title}" />
            </StackPanel>
            <!-- STATE 1: Heart Measurements -->
            <DataGrid
                Grid.Row="1"
                IsVisible="{Binding IsHeartPage}"
                ItemsSource="{Binding HeartMeasurements}"
                AutoGenerateColumns="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                CanUserSortColumns="True"
                Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Sys" Binding="{Binding Sys}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Dia" Binding="{Binding Dia}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Heart Rhythm" Binding="{Binding HRhythm}" Width="*" IsReadOnly="True" />
                    <DataGridCheckBoxColumn Header="Arrhythmia?" Binding="{Binding IsArrhythmia}" IsReadOnly="True"
                                            Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- STATE 2: Body Measurements -->
            <DataGrid Grid.Row="1"
                      IsVisible="{Binding IsBodyPage}"
                      ItemsSource="{Binding BodyMeasurements}"
                      AutoGenerateColumns="False"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Temperature" Binding="{Binding Temperature}" Width="*"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- STATE 3: Medicine -->
            <DataGrid Grid.Row="1"
                      IsVisible="{Binding IsMedicinePage}"
                      ItemsSource="{Binding Medicines}"
                      AutoGenerateColumns="False"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="M ID" Binding="{Binding Id}" Width="60" IsReadOnly="True" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Time Schedule" Binding="{Binding TimeScheduleString}" Width="*"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Day Schedule" Binding="{Binding DayScheduleString}" Width="*"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>