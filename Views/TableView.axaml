<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MEMOMed.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="MEMOMed.Views.TableView"
        x:DataType="vm:TableViewModel"
        Title="TableView">

    <Design.DataContext>
        <vm:TableViewModel />
    </Design.DataContext>

    <DockPanel Margin="10">
        <!-- Navigation Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <Button Command="{Binding GoBackCommand}" Content="Go Back" MinWidth="60" />
            <Button Command="{Binding HeartPChangeCommand}" Content="Heart Measurements" MinWidth="100" />
            <Button Command="{Binding BodyPChangeCommand}" Content="Body Measurements" MinWidth="100" />
            <Button Command="{Binding FeelingPChangeCommand}" Content="Feeling Measurements" MinWidth="100" />
            <Button Command="{Binding MedicinePChangeCommand}" Content="Medicine List" MinWidth="100" />
        </StackPanel>

        <!-- STATE 1: Heart Measurements -->
        <DataGrid IsVisible="{Binding IsHeartPage}"
                  ItemsSource="{Binding HeartMeasurements}"
                  AutoGenerateColumns="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="True"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                <DataGridTextColumn Header="Sys" Binding="{Binding Sys}" Width="*" />
                <DataGridTextColumn Header="Dia" Binding="{Binding Dia}" Width="*" />
                <DataGridTextColumn Header="Heart Rhythm" Binding="{Binding HRhythm}" Width="*" />
                <DataGridCheckBoxColumn Header="Arrhythmia?" Binding="{Binding IsArrhythmia}" IsReadOnly="True"
                                        Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATE 2: Body Measurements -->
        <DataGrid IsVisible="{Binding IsBodyPage}"
                  ItemsSource="{Binding BodyMeasurements}"
                  AutoGenerateColumns="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                <DataGridTextColumn Header="Temperature" Binding="{Binding Temperature}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATE 3: Feeling Measurements -->
        <DataGrid IsVisible="{Binding IsFeelingPage}"
                  ItemsSource="{Binding FeelingMeasurements}"
                  AutoGenerateColumns="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                <DataGridTextColumn Header="Medication" Binding="{Binding Medication}" Width="*" />
                <DataGridTextColumn Header="Feeling" Binding="{Binding Feeling}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATE 4: Medicine -->
        <DataGrid IsVisible="{Binding IsMedicinePage}"
                  ItemsSource="{Binding Medicines}"
                  AutoGenerateColumns="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Medicine ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Time Schedule" Binding="{Binding TimeScheduleString}" Width="*" />
                <DataGridTextColumn Header="Day Schedule" Binding="{Binding DayScheduleString}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>