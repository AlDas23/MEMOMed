<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MEMOMed.ViewModels"
             xmlns:components="clr-namespace:MEMOMed.Components"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="MEMOMed.Views.EditMeasurementsView"
             x:DataType="vm:EditMeasurementsViewModel"
             Width="600"
             Height="500"
             Padding="20">

    <DockPanel>
        <!-- Top Navigation Bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <Button Content="Go back"
                    DockPanel.Dock="Left"
                    Command="{Binding GoBackCommand}"
                    Margin="4" />
        </DockPanel>

        <!-- Form Area -->
        <Grid RowDefinitions="Auto,Auto">
            <Grid Grid.Row="0"
                  Margin="0,0,0,16"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="Auto,*">

                <!-- DatePicker -->
                <TextBlock Text="Date:"
                           Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <DatePicker Grid.Row="0" Grid.Column="1"
                            SelectedDate="{Binding SelectedDate}"
                            Margin="0,0,0,8" />

                <TextBlock Text="{Binding TextField1Name}"
                           Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8">
                </TextBlock>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding TextField1}"
                         Margin="0,0,0,8" />

                <TextBlock Text="{Binding TextField2Name}"
                           Grid.Row="2" Grid.Column="0"
                           IsVisible="{Binding IsTextField2Visible}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         IsVisible="{Binding IsTextField2Visible}"
                         Text="{Binding TextField2}"
                         Margin="0,0,0,8" />

                <TextBlock Text="{Binding TextField3Name}"
                           Grid.Row="3" Grid.Column="0"
                           IsVisible="{Binding IsTextField3Visible}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         IsVisible="{Binding IsTextField3Visible}"
                         Text="{Binding TextField3}"
                         Margin="0,0,0,8" />

                <TextBlock Text="{Binding TextField4Name}"
                           Grid.Row="4" Grid.Column="0"
                           IsVisible="{Binding IsTextField4Visible}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <TextBox Grid.Row="4" Grid.Column="1"
                         IsVisible="{Binding IsTextField4Visible}"
                         Text="{Binding TextField4}"
                         Height="60"
                         Margin="0,0,0,8" />

                <TextBlock Text="{Binding TextField5Name}"
                           Grid.Row="5" Grid.Column="0"
                           IsVisible="{Binding IsTextField5Visible}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <TextBox Grid.Row="5" Grid.Column="1"
                         IsVisible="{Binding IsTextField5Visible}"
                         Text="{Binding TextField5}"
                         Height="60"
                         Margin="0,0,0,8" />


                <CheckBox Grid.Row="6" Grid.Column="1"
                          Content="Arrhythmia?"
                          IsVisible="{Binding IsVisibleArrhythmiaCheckBox}"
                          IsChecked="{Binding IsArrhythmiaCheckBox}"
                          Margin="0,4,0,0" />
            </Grid>


            <StackPanel Grid.Row="1" HorizontalAlignment="Right" Spacing="10" Orientation="Horizontal">
                <components:ErrorMessage Message="{Binding ErrorMessage}"
                                         IsError="{Binding IsError}" />
                <Button
                    Command="{Binding EditCommand}"
                    Content="Update"
                    HorizontalAlignment="Right"
                    Padding="30,10"
                    Margin="0,10,0,0"
                    Foreground="DeepSkyBlue" />
                <Button
                    Command="{Binding DeleteCommand}"
                    Content="Delete"
                    HorizontalAlignment="Right"
                    Padding="30,10"
                    Margin="0,10,0,0"
                    Foreground="Crimson" />
            </StackPanel>
        </Grid>

    </DockPanel>
</UserControl>